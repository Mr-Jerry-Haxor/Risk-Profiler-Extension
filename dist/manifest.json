{
  "manifest_version": 3,
  "name": "Rest Profiler Review and Validate Automation",
  "version": "1.0.0",
  "description": "Risk Profiler Assessment Review and Validation Engine",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "alarms",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://cairois.web.boeing.com/*",
    "https://service-gateway.tas-phx.apps.boeing.com/*",
    "https://termbank.web.boeing.com/*",
    "https://esats.web.boeing.com/*",
    "https://gtc-ecm.web.boeing.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/encoded_data.txt"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "background": {
    "service_worker": "service_worker.bundle.js",
    "type": "module"
  },
  "action": {
    "default_title": "Rest Profiler Review and Validate Automation",
    "default_popup": "popup.html"
  }
}
